# ScraperAPI — required to fetch Tesco fuel prices (bypasses Akamai)
# Sign up free at https://www.scraperapi.com (1,000 req/month free tier)
SCRAPER_API_KEY=your_scraper_api_key_here

# UK Government Fuel Finder API (OAuth 2.0 client credentials)
# Register at https://www.developer.fuel-finder.service.gov.uk/public-api
FUEL_FINDER_CLIENT_ID=your_client_id_here
FUEL_FINDER_CLIENT_SECRET=your_client_secret_here
